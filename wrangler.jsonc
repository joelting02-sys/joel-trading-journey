{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trading-journey",
  "compatibility_date": "2026-07-03",
  "main": "src/entry-worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
